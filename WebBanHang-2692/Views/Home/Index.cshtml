@model IEnumerable<WebBanHang_2692.Models.Product>
@{
    ViewData["Title"] = "Trang chủ";
}

<div id="homeCarousel" class="carousel slide mb-4 shadow-sm rounded overflow-hidden" data-bs-ride="carousel">
    <div class="carousel-inner">
        <div class="carousel-item active">
            <img src="/images/Banner/banner1.jpg" class="d-block w-100" style="height: 280px; object-fit: cover;" alt="Banner 1">
        </div>
        <div class="carousel-item">
            <img src="/images/Banner/banner2.jpg" class="d-block w-100" style="height: 280px; object-fit: cover;" alt="Banner 2">
        </div>
        <div class="carousel-item">
            <img src="/images/Banner/banner3.jpg" class="d-block w-100" style="height: 280px; object-fit: cover;" alt="Banner 3">
        </div>
        <div class="carousel-item">
            <img src="/images/Banner/banner4.jpg" class="d-block w-100" style="height: 280px; object-fit: cover;" alt="Banner 4">
        </div>
    </div>
    <button class="carousel-control-prev" type="button" data-bs-target="#homeCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#homeCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
    </button>
</div>

<div class="row">
    <div class="col-lg-9 mb-4">
        <div class="mb-3 pb-2 border-bottom text-danger">
            <h4 class="fw-bold mb-0"><i class="bi bi-fire me-2"></i>SẢN PHẨM NỔI BẬT</h4>
        </div>

        <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-2">
            @foreach (var product in Model)
            {
                <div class="col">
                    <div class="card h-100 product-card bg-white rounded">
                        <img src="@product.ImageUrl" class="card-img-top p-2" alt="@product.Name" style="height: 160px; object-fit: contain;">

                        <div class="card-body text-center p-2 d-flex flex-column">
                            <h6 class="card-title text-dark fw-semibold text-truncate mb-1">@product.Name</h6>
                            <p class="card-text text-danger fw-bold mb-2">@product.Price.ToString("#,##0") đ</p>

                            <div class="mt-auto">
                                <a asp-controller="Product" asp-action="Display" asp-route-id="@product.Id" class="btn btn-sm btn-outline-danger w-100 py-1">
                                    Xem Chi Tiết
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="col-lg-3 d-none d-lg-block">
        <div class="sticky-top" style="top: 85px; z-index: 1;">
            <a href="#">
                <img src="https://picsum.photos/400/800?random=11" class="img-fluid w-100 vertical-banner shadow-sm" alt="Banner Quản Cáo">
            </a>
        </div>
    </div>
</div>