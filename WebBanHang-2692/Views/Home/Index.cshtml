@model IEnumerable<WebBanHang_2692.Models.Product>
@{
    ViewData["Title"] = "Trang chủ";
}

<style>
    /* Hiệu ứng hover cho nút mũi tên chuyển slide */
    .carousel-control-prev, .carousel-control-next {
        width: 8%; /* Thu gọn vùng bấm để không che mất nhiều ảnh */
        transition: background-color 0.3s ease;
    }
    .carousel-control-prev:hover, .carousel-control-next:hover {
        background-color: rgba(0, 0, 0, 0.3); /* Nền tối nhẹ khi di chuột */
    }
    .carousel-control-prev-icon, .carousel-control-next-icon {
        width: 3rem;
        height: 3rem;
        filter: drop-shadow(2px 4px 6px black); /* Tạo bóng viền giúp mũi tên nổi bật trên mọi nền ảnh */
        transition: transform 0.3s ease; /* Hiệu ứng chuyển động mượt */
    }
    .carousel-control-prev:hover .carousel-control-prev-icon {
        transform: scale(1.2) translateX(-4px); /* Phóng to và trượt nhẹ sang trái */
    }
    .carousel-control-next:hover .carousel-control-next-icon {
        transform: scale(1.2) translateX(4px); /* Phóng to và trượt nhẹ sang phải */
    }
</style>

<div id="homeCarousel" class="carousel slide mb-4 shadow-sm rounded overflow-hidden" data-bs-ride="carousel">
    <!-- Nút chuyển đổi (Indicators) của Bootstrap 5 -->
    <div class="carousel-indicators">
        <button type="button" data-bs-target="#homeCarousel" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Slide 1"></button>
        <button type="button" data-bs-target="#homeCarousel" data-bs-slide-to="1" aria-label="Slide 2"></button>
        <button type="button" data-bs-target="#homeCarousel" data-bs-slide-to="2" aria-label="Slide 3"></button>
    </div>

    <div class="carousel-inner">
        <div class="carousel-item active">
            <img src="/images/Banner/banner1.jpg" class="d-block w-100" style="aspect-ratio: 1200 / 240; object-fit: cover;" alt="Banner 1">
        </div>
        <div class="carousel-item">
            <img src="/images/Banner/banner2.jpg" class="d-block w-100" style="aspect-ratio: 1200 / 240; object-fit: cover;" alt="Banner 2">
        </div>
        <div class="carousel-item">
            <img src="/images/Banner/banner3.jpg" class="d-block w-100" style="aspect-ratio: 1200 / 240; object-fit: cover;" alt="Banner 3">
        </div>
    </div>
    
    <button class="carousel-control-prev" type="button" data-bs-target="#homeCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#homeCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
    </button>
</div>

<div class="row">
    <div class="col-lg-9 mb-4">
        <div class="mb-3 pb-2 border-bottom text-danger">
            <h4 class="fw-bold mb-0"><i class="bi bi-fire me-2"></i>SẢN PHẨM NỔI BẬT</h4>
        </div>

        <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-2">
            @foreach (var product in Model)
            {
                <div class="col">
                    <div class="card h-100 product-card shadow-sm border-0">
                        <div class="d-flex justify-content-between p-3">
                            <p class="lead mb-0 small text-muted">Combo Offer</p>
                            <div class="bg-info rounded-circle d-flex align-items-center justify-content-center shadow-1-strong"
                                 style="width: 30px; height: 30px;">
                                <p class="text-white mb-0 small" style="font-size: 11px;">HOT</p>
                            </div>
                        </div>

                        <img src="@product.ImageUrl" class="card-img-top px-3" alt="@product.Name" style="height: 150px; object-fit: contain;" />

                        <div class="card-body p-3 d-flex flex-column">
                            <div class="d-flex justify-content-between small mb-1">
                                <p class="small mb-0"><a href="#!" class="text-muted text-decoration-none">@(product.Category?.Name ?? "Chưa phân loại")</a></p>
                                <p class="small text-danger mb-0"><s>@((product.Price * 1.1m).ToString("#,##0")) đ</s></p>
                            </div>

                            <div class="d-flex justify-content-between mb-3">
                                <h6 class="mb-0 fw-bold text-truncate" style="max-width: 120px;">@product.Name</h6>
                                <h6 class="text-danger mb-0 fw-bold">@product.Price.ToString("#,##0") đ</h6>
                            </div>

                            <div class="d-flex justify-content-between mb-2 mt-auto align-items-center">
                                <p class="text-muted mb-0 small">Sẵn có: <span class="fw-bold text-success">6</span></p>
                                <div class="ms-auto text-warning small" style="font-size: 12px;">
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                </div>
                            </div>

                            <a asp-controller="Product" asp-action="Display" asp-route-id="@product.Id" class="btn btn-sm btn-danger w-100 py-1 mt-2">
                                Xem chi tiết
                            </a>
                        </div>
                    </div>
                </div>
            }

        </div>
        
        @if (ViewBag.TotalPages > 1)
        {
            <nav aria-label="Page navigation" class="mt-4 mb-2">
                <ul class="pagination justify-content-center">

                    <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                        <a class="page-link" asp-controller="Home" asp-action="Index" asp-route-page="@(ViewBag.CurrentPage - 1)">
                            <i class="bi bi-chevron-left"></i> Trước
                        </a>
                    </li>

                    @for (int i = 1; i <= ViewBag.TotalPages; i++)
                    {
                        <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                            <a class="page-link" asp-controller="Home" asp-action="Index" asp-route-page="@i">@i</a>
                        </li>
                    }

                    <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                        <a class="page-link" asp-controller="Home" asp-action="Index" asp-route-page="@(ViewBag.CurrentPage + 1)">
                            Tiếp <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>

                </ul>
            </nav>
        }
    </div>

    <div class="col-lg-3 d-none d-lg-block">
        <div class="sticky-top" style="top: 85px; z-index: 1;">
            <a href="#">
                <img src="/images/Banner/@(ViewBag.CurrentPage == 2 ? "vertical-banner-2.png" : "vertical-banner-1.jpg")" class="img-fluid w-100 vertical-banner shadow-sm" alt="Banner Quản Cáo">
            </a>
        </div>
    </div>
</div>